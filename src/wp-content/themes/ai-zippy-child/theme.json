{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"slug": "lollipop-red",
					"color": "#FF6B6B",
					"name": "Lollipop Red - Primary Hero"
				},
				{
					"slug": "sunshine",
					"color": "#FFE66D",
					"name": "Sunshine - Accent / CTA"
				},
				{
					"slug": "spearmint",
					"color": "#45B69C",
					"name": "Spearmint - Secondary Accent"
				},
				{
					"slug": "deep-ink",
					"color": "#2C3E7A",
					"name": "Deep Ink - Text / Nav"
				},
				{
					"slug": "warm-cream",
					"color": "#FFFBF4",
					"name": "Warm Cream - Page Background"
				},
				{
					"slug": "peach-pop",
					"color": "#FF8C69",
					"name": "Peach Pop - Tertiary / Tags"
				},
				{
					"slug": "text-muted",
					"color": "#6F6F77",
					"name": "Text Muted"
				},
				{
					"slug": "border",
					"color": "#E7E1D8",
					"name": "Border"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "White"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Bricolage Grotesque\", sans-serif",
					"slug": "bricolage-grotesque",
					"name": "Bricolage Grotesque",
					"fontFace": [
						{
							"fontFamily": "Bricolage Grotesque",
							"fontStyle": "normal",
							"fontWeight": "400 800",
							"src": [
								"file:./src/fonts/bricolage-grotesque.ttf"
							]
						}
					]
				},
				{
					"fontFamily": "\"DM Sans\", sans-serif",
					"slug": "dm-sans",
					"name": "DM Sans",
					"fontFace": [
						{
							"fontFamily": "DM Sans",
							"fontStyle": "normal",
							"fontWeight": "300 500",
							"src": [
								"file:./src/fonts/dm-sans.ttf"
							]
						},
						{
							"fontFamily": "DM Sans",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./src/fonts/dm-sans-italic.ttf"
							]
						}
					]
				},
				{
					"fontFamily": "\"Syne\", sans-serif",
					"slug": "syne",
					"name": "Syne",
					"fontFace": [
						{
							"fontFamily": "Syne",
							"fontStyle": "normal",
							"fontWeight": "700 800",
							"src": [
								"file:./src/fonts/syne.ttf"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "x-small",
					"size": "0.6875rem",
					"name": "Extra Small"
				},
				{
					"slug": "small",
					"size": "0.75rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1rem",
					"name": "Medium"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2.875rem",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "4.375rem",
					"name": "2X Large"
				},
				{
					"slug": "hero-stat",
					"size": "2rem",
					"name": "Hero Stat"
				}
			]
		},
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1735px"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--warm-cream)",
			"text": "var(--wp--preset--color--deep-ink)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--bricolage-grotesque)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "800",
					"lineHeight": "1.05"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "800",
					"lineHeight": "1"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "800",
					"lineHeight": "1.05"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"lineHeight": "1.12"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"lineHeight": "1.18"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--dm-sans)",
					"fontWeight": "500",
					"lineHeight": "1.1"
				}
			},
			"caption": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--dm-sans)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "400",
					"lineHeight": "1.45"
				}
			},
			"cite": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--dm-sans)",
					"fontStyle": "italic",
					"fontWeight": "400"
				}
			}
		}
	}
}
