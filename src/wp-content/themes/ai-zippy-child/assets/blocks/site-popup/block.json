{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/site-popup",
  "version": "1.0.0",
  "title": "Site - Popup",
  "category": "ai-zippy",
  "icon": "welcome-view-site",
  "description": "Custom promotional popup with display rules and remember settings.",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "popupId": {
      "type": "string",
      "default": "members-club"
    },
    "width": {
      "type": "number",
      "default": 500
    },
    "height": {
      "type": "number",
      "default": 0
    },
    "maxHeight": {
      "type": "number",
      "default": 88
    },
    "borderRadius": {
      "type": "number",
      "default": 22
    },
    "bannerHeight": {
      "type": "number",
      "default": 150
    },
    "trigger": {
      "type": "string",
      "default": "delay"
    },
    "delaySeconds": {
      "type": "number",
      "default": 5
    },
    "scrollPercent": {
      "type": "number",
      "default": 40
    },
    "targetSelector": {
      "type": "string",
      "default": ""
    },
    "showLauncherButton": {
      "type": "boolean",
      "default": false
    },
    "launcherText": {
      "type": "string",
      "default": "Open Offer"
    },
    "firstVisitOnly": {
      "type": "boolean",
      "default": false
    },
    "skipFirstVisit": {
      "type": "boolean",
      "default": false
    },
    "rememberOnClose": {
      "type": "boolean",
      "default": true
    },
    "showDontShowAgain": {
      "type": "boolean",
      "default": true
    },
    "dontShowLabel": {
      "type": "string",
      "default": "No thanks, I'll browse as guest"
    },
    "storageMode": {
      "type": "string",
      "default": "localStorage"
    },
    "suppressDays": {
      "type": "number",
      "default": 14
    },
    "closeOnOverlay": {
      "type": "boolean",
      "default": true
    },
    "badgeText": {
      "type": "string",
      "default": "MEMBERS GET MORE"
    },
    "heroImageId": {
      "type": "number",
      "default": 0
    },
    "heroImageUrl": {
      "type": "string",
      "default": ""
    },
    "heroImageAlt": {
      "type": "string",
      "default": ""
    },
    "heroIcons": {
      "type": "string",
      "default": "🧸 🎁 🎨 🧩 🚀"
    },
    "imageNote": {
      "type": "string",
      "default": "REPLACE WITH BRAND PHOTOGRAPHY"
    },
    "kicker": {
      "type": "string",
      "default": "MEMBERS GET MORE"
    },
    "heading": {
      "type": "string",
      "default": "Join the Tom & Stefanie Club"
    },
    "description": {
      "type": "string",
      "default": "Sign up for early access to new arrivals, exclusive deals, and a birthday treat - just for you."
    },
    "benefits": {
      "type": "array",
      "default": [
        {
          "icon": "🎟️",
          "label": "Welcome<br>Voucher"
        },
        {
          "icon": "🎂",
          "label": "Birthday<br>Treat"
        },
        {
          "icon": "⚡",
          "label": "Early<br>Access"
        },
        {
          "icon": "💰",
          "label": "Earn & Redeem<br>Points"
        }
      ]
    },
    "emailPlaceholder": {
      "type": "string",
      "default": "Enter your email address"
    },
    "formAction": {
      "type": "string",
      "default": ""
    },
    "emailFieldName": {
      "type": "string",
      "default": "email"
    },
    "buttonText": {
      "type": "string",
      "default": "Join Free Now"
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "buttonBackground": {
      "type": "string",
      "default": "#24231f"
    },
    "buttonColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "overlayColor": {
      "type": "string",
      "default": "rgba(0, 0, 0, 0.56)"
    },
    "backgroundColor": {
      "type": "string",
      "default": "#ffffff"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}