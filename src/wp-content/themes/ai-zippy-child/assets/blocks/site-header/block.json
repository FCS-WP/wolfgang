{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/site-header",
  "version": "1.0.0",
  "title": "Site Header",
  "category": "ai-zippy",
  "icon": "store",
  "description": "Premium shop header with promo bar, logo, navigation, utility icons, and CTA.",
  "keywords": [
    "header",
    "navigation",
    "menu",
    "logo"
  ],
  "supports": {
    "html": false,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "promoText": {
      "type": "string",
      "default": "Free delivery above $60 · Spend $80, get $12 off · New in: Micro Scooters just dropped · Shop Now ->"
    },
    "promoUrl": {
      "type": "string",
      "default": "/shop"
    },
    "logoBefore": {
      "type": "string",
      "default": "Tom"
    },
    "logoAccent": {
      "type": "string",
      "default": "&"
    },
    "logoAfter": {
      "type": "string",
      "default": "Stefanie"
    },
    "logoUrl": {
      "type": "string",
      "default": "/"
    },
    "logoImageId": {
      "type": "number",
      "default": 0
    },
    "logoImageUrl": {
      "type": "string",
      "default": ""
    },
    "logoImageAlt": {
      "type": "string",
      "default": ""
    },
    "logoImageWidth": {
      "type": "number",
      "default": 320
    },
    "logoImageMinHeight": {
      "type": "number",
      "default": 54
    },
    "logoImageObjectFit": {
      "type": "string",
      "default": "contain"
    },
    "logoImageObjectPosition": {
      "type": "string",
      "default": "center center"
    },
    "menuId": {
      "type": "number",
      "default": 0
    },
    "homeLabel": {
      "type": "string",
      "default": "Home"
    },
    "homeUrl": {
      "type": "string",
      "default": "/"
    },
    "shopLabel": {
      "type": "string",
      "default": "Shop"
    },
    "shopUrl": {
      "type": "string",
      "default": "/shop"
    },
    "giftLabel": {
      "type": "string",
      "default": "Gift"
    },
    "giftUrl": {
      "type": "string",
      "default": "/gift"
    },
    "trendingLabel": {
      "type": "string",
      "default": "Trending"
    },
    "trendingUrl": {
      "type": "string",
      "default": "/trending"
    },
    "contactLabel": {
      "type": "string",
      "default": "Contact Us"
    },
    "contactUrl": {
      "type": "string",
      "default": "/contact-us"
    },
    "searchUrl": {
      "type": "string",
      "default": "/?s="
    },
    "wishlistUrl": {
      "type": "string",
      "default": "/wishlist"
    },
    "cartUrl": {
      "type": "string",
      "default": "/cart"
    },
    "buttonText": {
      "type": "string",
      "default": "Shop Now"
    },
    "buttonUrl": {
      "type": "string",
      "default": "/shop"
    },
    "showPromo": {
      "type": "boolean",
      "default": true
    },
    "showSearch": {
      "type": "boolean",
      "default": true
    },
    "showWishlist": {
      "type": "boolean",
      "default": true
    },
    "showCart": {
      "type": "boolean",
      "default": true
    },
    "enableMegaMenu": {
      "type": "boolean",
      "default": true
    },
    "megaMenuParentLabel": {
      "type": "string",
      "default": "Shop"
    },
    "megaMenuAssignments": {
      "type": "array",
      "default": [
        {
          "parentLabel": "Shop",
          "megaMenuId": "shop-default"
        }
      ]
    },
    "megaMenuColumns": {
      "type": "array",
      "default": [
        {
          "heading": "BY OCCASION",
          "items": [
            {
              "icon": "⚡",
              "label": "Last Minute Birthday Gift",
              "url": "/shop-by-occasion/last-minute-birthday-gift",
              "badge": "URGENT",
              "highlight": false
            },
            {
              "icon": "🎂",
              "label": "Birthday",
              "url": "/shop-by-occasion/birthday",
              "badge": "",
              "highlight": false
            },
            {
              "icon": "👶",
              "label": "Baby Shower & 1st Month",
              "url": "/shop-by-occasion/baby-shower",
              "badge": "",
              "highlight": false
            },
            {
