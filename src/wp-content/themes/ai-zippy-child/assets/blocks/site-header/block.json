              "highlight": false
            },
            {
              "icon": "🚶",
              "label": "1-3 Years",
              "url": "/shop-by-age/1-3-years",
              "badge": "",
              "highlight": false
            },
            {
              "icon": "🧠",
              "label": "4-6 Years",
              "url": "/shop-by-age/4-6-years",
              "badge": "",
