        {
          "heading": "COLLECTIONS",
          "items": [
            {
              "icon": "✨",
              "label": "New Arrivals",
              "url": "/new-arrivals",
              "badge": "",
              "highlight": false
            },
            {
              "icon": "🔥",
              "label": "Trending Now",
