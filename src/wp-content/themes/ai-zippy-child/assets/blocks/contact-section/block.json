{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/contact-section",
  "version": "1.0.0",
  "title": "Contact Section",
  "category": "ai-zippy",
  "icon": "email-alt",
  "description": "Contact layout with shortcode form, location details, business hours, trade notes, and social link.",
  "keywords": [
    "contact",
    "enquiry",
    "form",
    "location"
  ],
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "eyebrow": {
      "type": "string",
      "default": "Send An Enquiry"
    },
    "heading": {
      "type": "string",
      "default": "B2B & Project Enquiries"
    },
    "formShortcode": {
      "type": "string",
      "default": ""
    },
    "responseNote": {
      "type": "string",
      "default": "We typically respond within 1–2 business days."
    },
    "backgroundColor": {
      "type": "string",
      "default": ""
    },
    "locationTitle": {
      "type": "string",
      "default": "Our Location"
    },
    "locationName": {
      "type": "string",
      "default": "Nature Teak Pte Ltd"
    },
    "locationAddress": {
      "type": "string",
      "default": "Sungei Kadut, Singapore"
    },
    "locationTagline": {
      "type": "string",
      "default": "Singapore's premier timber & wood hub"
    },
    "mapImageId": {
      "type": "number",
      "default": 0
    },
    "mapImageUrl": {
      "type": "string",
      "default": ""
    },
    "mapAlt": {
      "type": "string",
      "default": ""
    },
    "mapEmbedHtml": {
      "type": "string",
      "default": ""
    },
    "mapTitle": {
      "type": "string",
      "default": "Sungei Kadut Timber Hub"
    },
    "mapSubtitle": {
      "type": "string",
      "default": "Singapore"
    },
    "mapLinkText": {
      "type": "string",
      "default": "Open in Google Maps"
    },
    "mapLinkUrl": {
      "type": "string",
      "default": "#"
    },
    "hoursTitle": {
      "type": "string",
      "default": "Operating Hours"
    },
    "hoursLineOneLabel": {
      "type": "string",
      "default": "Mon – Fri"
    },
    "hoursLineOneValue": {
      "type": "string",
      "default": "8am – 5:30pm"
    },
    "hoursLineTwoLabel": {
      "type": "string",
      "default": "Saturday"
    },
    "hoursLineTwoValue": {
      "type": "string",
      "default": "8am – 1pm"
    },
    "hoursLineThreeLabel": {
      "type": "string",
      "default": "Sunday"
    },
    "hoursLineThreeValue": {
      "type": "string",
      "default": "Closed"
    },
    "hoursLineFourLabel": {
      "type": "string",
      "default": "Public Holidays"
    },
    "hoursLineFourValue": {
      "type": "string",
      "default": "Closed"
    },
    "tradeTitle": {
      "type": "string",
      "default": "Trade Enquiries"
    },
    "tradeOne": {
      "type": "string",
      "default": "B2B wholesale pricing available"
    },
    "tradeTwo": {
      "type": "string",
      "default": "Custom milling and cutting to spec"
    },
    "tradeThree": {
      "type": "string",
      "default": "Bulk orders and project supply"
    },
    "tradeFour": {
      "type": "string",
      "default": "Wood grading expertise & guidance"
    },
    "followTitle": {
      "type": "string",
      "default": "Follow Us"
    },
    "followButtonText": {
      "type": "string",
      "default": "Nature Teak Wood on Facebook"
    },
    "followButtonUrl": {
      "type": "string",
      "default": "#"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}