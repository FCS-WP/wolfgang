{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/shop-page",
  "version": "1.0.0",
  "title": "Shop Page",
  "category": "ai-zippy",
  "icon": "products",
  "description": "SEO shop archive with category pills, filters, product grid, and mobile filter drawer.",
  "supports": {
    "html": false,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}