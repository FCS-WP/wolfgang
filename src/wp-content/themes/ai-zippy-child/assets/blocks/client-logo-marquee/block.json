{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "ai-zippy-child/client-logo-marquee",
  "version": "1.0.0",
  "title": "Client Logo Marquee",
  "category": "ai-zippy-page",
  "icon": "images-alt2",
  "description": "Infinite scrolling row of client logos.",
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "align": {
      "type": "string",
      "default": "full"
    },
    "layout": {
      "type": "string",
      "default": "boxed"
    },
    "backgroundColor": {
      "type": "string",
      "default": "#000000"
    },
    "textColor": {
      "type": "string",
      "default": "#ffffff"
    },
    "paddingTop": {
      "type": "number",
      "default": 70
    },
    "paddingRight": {
      "type": "number",
      "default": 0
    },
    "paddingBottom": {
      "type": "number",
      "default": 120
    },
    "paddingLeft": {
      "type": "number",
      "default": 0
    },
    "marginTop": {
      "type": "number",
      "default": 0
    },
    "marginBottom": {
      "type": "number",
      "default": 0
    },
    "paddingTopTablet": {
      "type": "number"
    },
    "paddingRightTablet": {
      "type": "number"
    },
    "paddingBottomTablet": {
      "type": "number"
    },
    "paddingLeftTablet": {
      "type": "number"
    },
    "marginTopTablet": {
      "type": "number"
    },
    "marginBottomTablet": {
      "type": "number"
    },
    "paddingTopMobile": {
      "type": "number"
    },
    "paddingRightMobile": {
      "type": "number"
    },
    "paddingBottomMobile": {
      "type": "number"
    },
    "paddingLeftMobile": {
      "type": "number"
    },
    "marginTopMobile": {
      "type": "number"
    },
    "marginBottomMobile": {
      "type": "number"
    },
    "logos": {
      "type": "array",
      "default": []
    },
    "speed": {
      "type": "number",
      "default": 36
    },
    "logoSize": {
      "type": "number",
      "default": 92
    },
    "gap": {
      "type": "number",
      "default": 48
    },
    "pauseOnHover": {
      "type": "boolean",
      "default": true
    },
    "reverse": {
      "type": "boolean",
      "default": false
    }
  },
  "textdomain": "ai-zippy-child",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}